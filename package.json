{
  "name": "aictx-cli",
  "version": "1.2.0",
  "description": "Context as Code (CaC) CLI for AI-Assisted Engineering",
  "type": "module",
  "bin": {
    "aictx": "dist/aictx.js"
  },
  "files": [
    "dist",
    "vendor"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "sync:graphify": "node scripts/sync-graphify.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://gitee.com/kings2017/aictx-cli.git"
  },
  "keywords": [
    "ai",
    "cli",
    "context",
    "cac",
    "llm",
    "agent",
    "trae",
    "cursor",
    "rules"
  ],
  "author": "kings2017",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "cac": "^7.0.0",
    "consola": "^3.2.3",
    "execa": "^8.0.1",
    "fs-extra": "^11.3.4",
    "globby": "^16.2.0",
    "graphify-go": "^1.0.0",
    "gray-matter": "^4.0.3",
    "ollama": "^0.6.3",
    "picocolors": "^1.1.1",
    "tinyexec": "^0.3.2",
    "tinyglobby": "^0.2.10"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
